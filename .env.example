# ResetOS Environment Variables — copy to .env and fill in values
EXPO_PUBLIC_API_URL=http://localhost:3001/api
EXPO_PUBLIC_OPENAI_KEY=sk-your-openai-key-here
EXPO_PUBLIC_FB_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FB_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FB_PROJECT_ID=your-project-id
EXPO_PUBLIC_FB_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FB_MESSAGING_ID=your-messaging-sender-id
EXPO_PUBLIC_FB_APP_ID=your-app-id

# Backend Only
PORT=3001
OPENAI_API_KEY=sk-your-openai-key-here
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccount.json
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
NODE_ENV=development
